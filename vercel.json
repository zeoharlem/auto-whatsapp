{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/main.js"
    }
  ],
  "crons": [
    {
      "path": "/cron/devotional",
      "schedule": "0 6 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "api/index.ts"
    }
  ]
}